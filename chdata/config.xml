<?xml version="1.0"?>
<clickhouse>
    <logger>
        <level>warning</level>
        <console>true</console>
    </logger>

    <http_port>8123</http_port>
    <tcp_port>9000</tcp_port>
    <listen_host>127.0.0.1</listen_host>
    <listen_host>::1</listen_host>

    <path>./chdata/data/</path>
    <tmp_path>./chdata/tmp/</tmp_path>
    <user_files_path>./chdata/user_files/</user_files_path>

    <mark_cache_size>5368709120</mark_cache_size>
    <mlock_executable>false</mlock_executable>

    <users>
        <default>
            <!-- DEV ONLY: loopback-bound server with a short password. Do NOT copy this user block into any deployed config. -->
            <password>dev</password>
            <networks>
                <ip>127.0.0.1/32</ip>
                <ip>::1/128</ip>
            </networks>
            <profile>default</profile>
            <quota>default</quota>
            <access_management>0</access_management>
        </default>
    </users>

    <profiles>
        <default></default>
    </profiles>

    <quotas>
        <default></default>
    </quotas>

    <default_profile>default</default_profile>
    <default_database>default</default_database>
</clickhouse>
